{
  "name": "mikrotik-client",
  "version": "1.0.0",
  "description": "Mikrotik API client for Node.js with connection pool and queue system",
  "license": "Apache-2.0",
  "author": "",
  "keywords": ["mikrotik", "routeros", "api", "routerboard", "network"],
  "repository": {
    "type": "git",
    "url": ""
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
